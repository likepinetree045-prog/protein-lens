# ─────────────────────────────────────────────────────────────
# Protein Lens — 환경 변수
# 배포는 SETUP.md를 위→아래로 따라가면 됩니다. (모바일만으로 완결)
# ─────────────────────────────────────────────────────────────

# Google AI Studio (https://aistudio.google.com/apikey) — 모바일에서 발급 가능
GEMINI_API_KEY=

# 비전 모델. 무료 한도/limit:0 회피용으로 교체 가능.
GEMINI_MODEL=gemini-2.5-flash

# ── DB (Neon via Vercel 마켓플레이스) ────────────────────────
# Vercel Storage 탭에서 Neon을 연결하면 아래가 "자동 주입"됩니다 (직접 입력 불필요).
# 신형: DATABASE_URL / DATABASE_URL_UNPOOLED
# 구형: POSTGRES_URL / POSTGRES_URL_NON_POOLING / PGHOST 등
# 로컬 개발에서만 수동으로 하나 채우세요:
DATABASE_URL=

# ── /api/debug 보호 ──────────────────────────────────────────
# 디버그 엔드포인트 접근용 시크릿. 생성: openssl rand -hex 32
DEBUG_SECRET=

# (v1 미사용) 앱 전체 접근을 토큰으로 막고 싶을 때만. 현재는 공개 링크 운영.
# APP_ACCESS_TOKEN=
